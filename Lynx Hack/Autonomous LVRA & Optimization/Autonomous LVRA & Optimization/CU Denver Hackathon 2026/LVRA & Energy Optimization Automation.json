      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "actual_ach_occupied",
              "type": "number",
              "value": "={{ (60 * $('Collect All Lab Data').item.json.occ_SA_F) / ($('Collect All Lab Data').item.json.net_square_footage * 10) }}"
            },
            {
              "id": "2",
              "name": "actual_ach_unoccupied",
              "type": "number",
              "value": "={{ (60 * $('Collect All Lab Data').item.json.unocc_SA_F/  ($('Collect All Lab Data').item.json.net_square_footage* 10)) }}"
