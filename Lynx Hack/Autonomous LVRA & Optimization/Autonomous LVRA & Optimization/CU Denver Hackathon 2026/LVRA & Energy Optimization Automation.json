    {
      "parameters": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n    body { font-family: 'Helvetica', 'Arial', sans-serif; line-height: 1.6; color: #333; margin: 40px; }\n    .header { border-bottom: 2px solid #4A90E2; padding-bottom: 10px; margin-bottom: 30px; }\n    h1 { color: #1A365D; margin-bottom: 5px; font-size: 24px; }\n    .meta { font-size: 12px; color: #666; text-transform: uppercase; letter-spacing: 1px; }\n    \n    .section { margin-bottom: 25px; }\n    .section-title { font-weight: bold; color: #2D3748; border-left: 4px solid #4A90E2; padding-left: 10px; margin-bottom: 10px; font-size: 18px; }\n    \n    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; background: #F7FAFC; padding: 15px; border-radius: 8px; }\n    .stat-item { font-size: 14px; }\n    .stat-label { font-weight: bold; color: #4A5568; }\n    \n    .justification { font-style: italic; background: #EDF2F7; padding: 15px; border-radius: 5px; }\n    .footer { margin-top: 50px; font-size: 10px; text-align: center; color: #A0AEC0; border-top: 1px solid #E2E8F0; padding-top: 10px; }\n</style>\n</head>\n<body>\n\n    <div class=\"header\">\n        <h1>{{ $json.output.report_title }}</h1>\n        <div class=\"meta\">Ventilation Optimization & Safety Assessment Report</div>\n    </div>\n\n    <div class=\"stats-grid\">\n        <div class=\"stat-item\">\n            <span class=\"stat-label\">Occupied ACH (Before/After):</span><br>\n            {{ $json.output.before_ach_occupied }} / {{ $json.output.after_ach_occupied }}\n        </div>\n        <div class=\"stat-item\">\n            <span class=\"stat-label\">Unoccupied ACH (Before/After):</span><br>\n           {{ $json.output.before_ach_unoccupied }} / {{ $json.output.after_ach_unoccupied }}\n        </div>\n    </div>\n\n    <div class=\"section\">\n        <div class=\"section-title\">Energy Savings Analysis</div>\n        <p>{{ $json.output.energy_savings_explanation }}</p>\n    </div>\n\n    <div class=\"section\">\n        <div class=\"section-title\">Safety Justification</div>\n        <div class=\"justification\">\n            {{ $json.output.safety_justification }}\n        </div>\n    </div>\n\n    <div class=\"section\">\n        <div class=\"section-title\">LVDL Classification Reasoning</div>\n        <p>{{ $json.output.lvdl_classification_reasoning }}</p>\n    </div>\n\n    <div class=\"footer\">\n        Generated via n8n Automation System • Confidential Internal Report\n    </div>\n\n</body>\n</html>"
