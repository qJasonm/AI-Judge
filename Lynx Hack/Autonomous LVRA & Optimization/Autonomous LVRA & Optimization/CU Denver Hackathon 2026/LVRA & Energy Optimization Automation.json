      "id": "302e70ed-0bee-4c7d-8afa-9ab3b1707d32",
      "name": "Calculate Actual ACH",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        2288,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst saValues = items\n  .map((item) => {\n    // .replace(/,/g, '') removes all commas from the text\n    const rawValue = item?.json[\"608.1 \"]?.toString() || \"\";\n    return parseFloat(rawValue.replace(/,/g, ''));\n  })\n  .filter((value) => !isNaN(value));\n\nconst eaValues = items\n  .map((item) => {\n    const rawValue = item?.json[\"834.8 \"]?.toString() || \"\";\n    return parseFloat(rawValue.replace(/,/g, ''));\n  })\n  .filter((value) => !isNaN(value));\n\nconst occ_SA_F = Math.max(...saValues);\nconst unocc_SA_F = Math.min(...saValues);\nconst occ_EA_F = Math.max(...eaValues);\nconst unocc_EA_F = Math.min(...eaValues);\n\nreturn [{ json: { occ_SA_F, unocc_SA_F, occ_EA_F, unocc_EA_F } }];"
      },
