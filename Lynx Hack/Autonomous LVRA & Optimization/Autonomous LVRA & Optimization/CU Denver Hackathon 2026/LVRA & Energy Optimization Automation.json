    {
      "parameters": {
        "jsonSchemaExample": "{\n\n\"report_title\": \"ACH Optimization Report - Room 2107\",\n\n\"before_ach_occupied\": 15.2,\n\n\"before_ach_unoccupied\": 8.5,\n\n\"after_ach_occupied\": 12,\n\n\"after_ach_unoccupied\": 6,\n\n\"energy_savings_explanation\": \"By reducing occupied ACH from 15.2 to 12 and unoccupied from 8.5 to 6, we reduce fan energy consumption by approximately 20%, saving an estimated 15,000 kWh annually.\",\n\n\"safety_justification\": \"The LVRA assessment shows low hazard ratings with good housekeeping and effective ventilation, resulting in a total LVRA score of 12. This justifies LVDL 2 classification requiring only 12 ACH occupied and 6 ACH unoccupied, maintaining safety while eliminating over-ventilation.\",\n\n\"lvdl_classification_reasoning\": \"The previous LVDL 3 classification was overly conservative. The actual chemical usage, minimal generation rates, and presence of appropriate fume hoods mean the room does not require the higher ventilation rates of LVDL 3. The LVRA methodology confirms LVDL 2 is appropriate and safe.\"\n\n} "
      },
      "id": "45a52e19-a2d2-4003-98ab-a78be627788c",
